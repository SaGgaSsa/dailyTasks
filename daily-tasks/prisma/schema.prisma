generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int           @id @default(autoincrement())
  email         String        @unique
  password      String
  name          String?
  username      String        @unique
  role          UserRole      @default(DEV)
  technologies  TechStack[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  assignments        Assignment[]
  ownedWorkspaces    Workspace[]     @relation("OwnedWorkspaces")
  workspaces         WorkspaceMember[]

  @@map("users")
}

model Workspace {
  id        Int       @id @default(autoincrement())
  name      String
  ownerId   Int
  owner     User      @relation("OwnedWorkspaces", fields: [ownerId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  members   WorkspaceMember[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          Int             @id @default(autoincrement())
  userId      Int
  workspaceId Int
  role        WorkspaceRole   @default(MEMBER)
  joinedAt    DateTime        @default(now())

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@map("workspace_members")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum UserRole {
  ADMIN
  DEV
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskType {
  I_MODAPL
  I_CASO
  I_CONS
}

enum TechStack {
  SISA
  WEB
  ANDROID
  ANGULAR
  SPRING
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model Incidence {
  id            Int       @id @default(autoincrement())
  type          TaskType
  externalId    Int
  title         String
  description   String?   @db.Text
  status        TaskStatus @default(BACKLOG)
  priority      Priority   @default(MEDIUM)
  technology    TechStack
  estimatedTime Int?
  
  position      Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assignments   Assignment[]

  @@unique([type, externalId])
  @@map("incidences")
}

model Assignment {
  id             Int       @id @default(autoincrement())
  
  incidenceId    Int
  incidence      Incidence @relation(fields: [incidenceId], references: [id], onDelete: Cascade)
  userId         Int
  user           User      @relation(fields: [userId], references: [id])

  remainingHours Int?
  isAssigned     Boolean   @default(true)
  tasks          SubTask[]

  @@unique([incidenceId, userId])
  @@map("assignments")
}

model SubTask {
  id          Int       @id @default(autoincrement())
  title       String
  isCompleted Boolean   @default(false)
  
  assignmentId Int
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime  @default(now())

  @@map("sub_tasks")
}
