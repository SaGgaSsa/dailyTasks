generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int           @id @default(autoincrement())
  email         String        @unique
  password      String
  name          String?
  username      String        @unique
  role          UserRole      @default(DEV)
  technologies  TechStack[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  assignments        Assignment[]

  @@map("users")
}

enum UserRole {
  ADMIN
  DEV
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskType {
  I_MODAPL
  I_CASO
  I_CONS
}

enum TechStack {
  SISA
  WEB
  ANDROID
  ANGULAR
  SPRING
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model Incidence {
  id            Int       @id @default(autoincrement())
  type          TaskType
  externalId    Int
  title         String
  description   String?   @db.Text
  status        TaskStatus @default(BACKLOG)
  priority      Priority   @default(MEDIUM)
  technology    TechStack
  estimatedTime Int?
  
  position      Float     @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assignments   Assignment[]

  @@unique([type, externalId])
  @@map("incidences")
}

model Assignment {
  id             Int       @id @default(autoincrement())
  
  incidenceId    Int
  incidence      Incidence @relation(fields: [incidenceId], references: [id], onDelete: Cascade)
  userId         Int
  user           User      @relation(fields: [userId], references: [id])
  
  assignedHours Int?
  isAssigned     Boolean   @default(true)
  tasks          SubTask[]
  
  @@unique([incidenceId, userId])
  @@map("assignments")
}

model SubTask {
  id          Int       @id @default(autoincrement())
  title       String
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  
  assignmentId Int
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime  @default(now())

  @@map("sub_tasks")
}
