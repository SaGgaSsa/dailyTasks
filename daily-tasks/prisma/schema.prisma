generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int           @id @default(autoincrement())
  email         String        @unique
  password      String
  name          String?
  username      String        @unique
  role          UserRole      @default(DEV)
  technologies  Technology[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  createdTracklists   Tracklist[]
  reportedTickets    TicketQA[]  @relation("ReportedBy")
  assignedTickets    TicketQA[]  @relation("AssignedTo")

  assignments        Assignment[]
  attachments        Attachment[]
  pages              IncidencePage[]

  @@map("users")
}

enum UserRole {
  ADMIN
  DEV
  QA
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskType {
  I_MODAPL
  I_CASO
  I_CONS
}

model Technology {
  id            Int           @id @default(autoincrement())
  name          String        @unique
  isDefault     Boolean       @default(false)

  users         User[]
  incidences    Incidence[]
  modules       Module[]

  @@map("technologies")
}

model Module {
  id            Int           @id @default(autoincrement())
  name          String
  slug          String        @unique
  technologyId  Int
  technology    Technology    @relation(fields: [technologyId], references: [id], onDelete: Cascade)
  isDefault     Boolean       @default(false)

  @@map("modules")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum AttachmentType {
  FILE
  LINK
}

model Incidence {
  id            Int       @id @default(autoincrement())
  type          TaskType
  externalId    Int
  title         String
  comment      String?   @db.Text
  status        TaskStatus @default(BACKLOG)
  priority      Priority   @default(MEDIUM)
  technology    Technology @relation(fields: [technologyId], references: [id])
  technologyId  Int
  tracklistId  Int?
  tracklist    Tracklist? @relation(fields: [tracklistId], references: [id])
  estimatedTime Int?
  completedAt   DateTime?
  
  position      Float     @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assignments   Assignment[]
  attachments   Attachment[]
  pages         IncidencePage[]
  qaTickets     TicketQA[]

  @@unique([type, externalId])
  @@map("incidences")
}

model Assignment {
  id             Int       @id @default(autoincrement())
  
  incidenceId    Int
  incidence      Incidence @relation(fields: [incidenceId], references: [id], onDelete: Cascade)
  userId         Int
  user           User      @relation(fields: [userId], references: [id])
  
  assignedHours Int?
  isAssigned     Boolean   @default(true)
  tasks          SubTask[]
  
  @@unique([incidenceId, userId])
  @@map("assignments")
}

model SubTask {
  id          Int       @id @default(autoincrement())
  title       String
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  
  assignmentId Int
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime  @default(now())

  @@map("sub_tasks")
}

model Attachment {
  id           Int            @id @default(autoincrement())
  type         AttachmentType @default(FILE)
  name         String
  originalName String?
  url          String
  size         Int?
  mimeType     String?
  description  String?
  
  incidenceId  Int
  incidence    Incidence @relation(fields: [incidenceId], references: [id], onDelete: Cascade)
  
  uploadedById Int
  uploadedBy   User      @relation(fields: [uploadedById], references: [id])
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("attachments")
}

model IncidencePage {
  id          Int       @id @default(autoincrement())
  title       String
  content     Json?
  isMainPage  Boolean   @default(false)
  
  incidenceId Int
  incidence   Incidence @relation(fields: [incidenceId], references: [id], onDelete: Cascade)
  
  authorId    Int
  author      User      @relation(fields: [authorId], references: [id])
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("incidence_pages")
}

model Tracklist {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  dueDate     DateTime?
  createdById Int
  createdBy   User      @relation(fields: [createdById], references: [id])
  tickets     TicketQA[]
  incidences  Incidence[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("tracklists")
}

model TicketQA {
  id                Int       @id @default(autoincrement())
  ticketNumber      Int       @default(autoincrement())
  tracklistId       Int
  tracklist         Tracklist @relation(fields: [tracklistId], references: [id], onDelete: Cascade)
  type              String
  module            String
  description       String
  priority          String
  impact            Boolean      @default(false)
  tramite           String?
  reportedById      Int
  reportedBy        User      @relation("ReportedBy", fields: [reportedById], references: [id])
  assignedToId      Int?
  assignedTo        User?     @relation("AssignedTo", fields: [assignedToId], references: [id])
  incidenceId       Int?
  incidence         Incidence? @relation(fields: [incidenceId], references: [id])
  status            String    @default("Nuevo")
  verificationStatus String   @default("Analizar")
  correctionStatus  String    @default("Pendiente")
  logs              String?   @db.Text
  observations      String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([tracklistId, ticketNumber])
  @@map("tickets_qa")
}
